# SteamDT API Key used by Next.js API routes
STEAMDT_API_KEY=
STEAMDT_API_KEYS=

# Optional WebSocket base URL for live updates.
# Leave empty to use same-origin (http->ws, https->wss).
# Local direct mode example: ws://localhost:8001
NEXT_PUBLIC_WS_URL=

# Optional Backend API base URL (FastAPI).
# Leave empty to use same-origin (recommended with reverse proxy).
# Local direct mode example: http://localhost:8000
NEXT_PUBLIC_API_URL=
