# CS 饰品数据采集系统 - 环境变量配置

# ==========================================
# 第三方API配置
# ==========================================

# Pricempire API (历史数据)
# 获取地址: https://pricempire.com/api
# 免费额度: 100次/天

# SteamDT API (用于全量基础库/磨损查询；当前也用于 Youpin 价格)
# 官方文档: https://steamdt.com/
# 多Key轮换策略: 提高请求额度
STEAMDT_API_KEY_1=
STEAMDT_API_KEY_2=
STEAMDT_API_KEY_3=
STEAMDT_API_KEY_4=
STEAMDT_API_KEY_5=
STEAMDT_API_KEYS=
STEAMDT_TEST_INSPECT_URL=
STEAMDT_TEST_NOTIFY_URL=

# CSQAQ 企业接口 (当前主数据源，保留 SteamDT 作为回退)
# 官方文档: https://docs.csqaq.com/
# 企业地址示例: https://private-api.csqaq.com
CSQAQ_BASE_URL=https://private-api.csqaq.com
CSQAQ_API_TOKEN=
CSQAQ_PRIMARY_ENABLED=true
PRICE_PRIMARY_SOURCE=csqaq
BASE_SYNC_PRIMARY_SOURCE=csqaq
SEARCH_ITEMS_SOURCE=csqaq
CSQAQ_PURE_SEARCH=true
CSQAQ_COOLDOWN_SECONDS=300
CSQAQ_PRICE_CACHE_TTL_SECONDS=300
CSQAQ_PRICE_STALE_TTL_SECONDS=86400
CSQAQ_REFRESH_LOCK_TTL_SECONDS=30
CSQAQ_GLOBAL_QPS=1
CSQAQ_GLOBAL_QPS_KEY=quota:csqaq:global:qps
CSQAQ_SYNC_MIN_PRIORITY=
CSQAQ_SYNC_BATCH_SIZE=1000
CSQAQ_SYNC_MAX_BUFFER=5000
CSQAQ_SYNC_ONLY_ACTIVE=true
SNAPSHOT_HISTORY_MAX_POINTS=2880
SNAPSHOT_HISTORY_TTL_SECONDS=691200

# Buff 直连配置
# BUFF_GOODS_ID_MAP_FILE: 商品名 -> goods_id 的映射(可选)
# BUFF_SEARCH_ENABLED=true 且提供 BUFF_COOKIES_FILE 可启用搜索 fallback
BUFF_GOODS_ID_MAP_FILE=
BUFF_COOKIES_FILE=
BUFF_SEARCH_ENABLED=false
BUFF_PROXY_URL=
BUFF_PROXIES=

# 悠悠有品 (UU有品) 直连配置(可选；不配则使用 SteamDT)
# YOUPIN_HEADERS_FILE: 设备指纹请求头文件
# YOUPIN_TEMPLATE_MAP_FILE: 物品名 -> template_id 映射
YOUPIN_HEADERS_FILE=
YOUPIN_TEMPLATE_MAP_FILE=
YOUPIN_PROXY_URL=
YOUPIN_PROXIES=

# ==========================================
# 数据库配置
# ==========================================

# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/cs_items
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/cs_items
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cs_items
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ==========================================
# DragonflyDB 配置
# ==========================================

DRAGONFLY_URL=redis://:your_dragonfly_password@localhost:6379/0
DRAGONFLY_PASSWORD=your_dragonfly_password_here
DRAGONFLYDB_HOST=localhost
DRAGONFLYDB_PORT=6379
DRAGONFLYDB_PASSWORD=your_dragonfly_password_here
DRAGONFLYDB_DB=0

# ==========================================
# Celery 配置
# ==========================================

CELERY_BROKER_URL=redis://:your_dragonfly_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_dragonfly_password@localhost:6379/2
CELERY_WORKER_CONCURRENCY=2
# 仅 CSQAQ 模式：默认关闭旧的 steam/buff/youpin 采集链路
ENABLE_LEGACY_MULTI_PLATFORM_SCRAPE=false

# ==========================================
# 应用配置
# ==========================================

# JWT 认证
SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# 允许过期 access token 在此窗口内换新（分钟）
ACCESS_TOKEN_REFRESH_GRACE_MINUTES=1440

# 启动时默认管理员初始化
# 仅在用户不存在时创建；若需每次启动强制重置为下列凭据，设置 RESET_DEFAULT_ADMIN_ON_STARTUP=true
DEFAULT_ADMIN_USERNAME=root
DEFAULT_ADMIN_PASSWORD=root
# 推荐：使用启动密钥覆盖默认管理员密码（优先于 DEFAULT_ADMIN_PASSWORD）
DEFAULT_ADMIN_BOOTSTRAP_KEY=
# 可选：超级管理员可用该密钥直接登录（无需输入密码）
ADMIN_LOGIN_KEY=
DEFAULT_ADMIN_EMAIL=root@local
RESET_DEFAULT_ADMIN_ON_STARTUP=false

# CORS (FastAPI)
CORS_ORIGINS=http://localhost:3000

# 采集配置 (限流策略)
# Steam Market (官方API)
STEAM_DELAY_MIN=2.0
STEAM_DELAY_MAX=3.0

# Buff163 (直连)
BUFF_DELAY_MIN=2.5
BUFF_DELAY_MAX=3.5

# 悠悠有品 (直连)
YOUPIN_DELAY_MIN=2.5
YOUPIN_DELAY_MAX=3.5

# SteamDT API 通用配置
STEAMDT_DELAY_MIN=1.5
STEAMDT_DELAY_MAX=2.5
STEAMDT_MAX_REQUESTS_PER_MINUTE=30

# 日志配置
LOG_LEVEL=INFO

# 实例ID (用于高可用部署)
INSTANCE_ID=instance-A

# 套利计算与通知
ARBITRAGE_SOURCE=csqaq
ARBITRAGE_DIRECTION=youpin_to_buff
ARBITRAGE_MIN_LIQUIDITY=10
ARBITRAGE_MAX_SPREAD_RATIO_PCT=15
ARBITRAGE_WITHDRAWAL_RATE=0.99
# Buff 侧流动性硬过滤（防“高挂单低成交/假深度”）
ARBITRAGE_MIN_BUFF_BUY_ORDERS=30
ARBITRAGE_MAX_BUFF_SELL_BUY_RATIO=8
ARBITRAGE_MIN_BUFF_BUY_TO_YOUPIN_SELL_RATIO=0.2
ARBITRAGE_RECHECK_ROI_PCT=20
ARBITRAGE_RECHECK_MAX_PER_RUN=3
ARBITRAGE_STRICT_RECHECK=true
ARBITRAGE_VERIFY_NOTIFY_MIN_PROFIT_RATE=20
ARBITRAGE_NOTIFY_MIN_PROFIT_RATE=8
ARBITRAGE_NOTIFY_MAX_ITEMS=5
# 任务9: 进阶阈值与分类过滤
ARBITRAGE_LIQUIDITY_TRAP_MIN_DUAL_DAILY_VOLUME=10
ARBITRAGE_MAIN_POOL_MIN_DUAL_DAILY_VOLUME=1500
ARBITRAGE_TIER_LIGHT_MIN_SPREAD_PCT=3
ARBITRAGE_TIER_MEDIUM_MIN_SPREAD_PCT=5
ARBITRAGE_TIER_ANOMALY_MIN_SPREAD_PCT=8
ARBITRAGE_DRAWDOWN_STOP_SPREAD_PCT=1.2
ARBITRAGE_STICKER_MIN_NET_PROFIT=0.5
ARBITRAGE_CASE_CONFIRM_ENABLED=true
ARBITRAGE_CASE_CONFIRM_CONSECUTIVE_HOURS=2
ARBITRAGE_CASE_CONFIRM_LOOKBACK_HOURS=6
# v2 时序策略参数（快照历史 + 日K）
ARBITRAGE_STRATEGY_SNAPSHOT_LOOKBACK_POINTS=2880
ARBITRAGE_REQUIRE_TIMING_SIGNAL=false
ARBITRAGE_RISK_FREE_MIN_ROI_PCT=3.5
ARBITRAGE_VOLUME_BREAKOUT_MIN_SELL_DROP_PCT=15
ARBITRAGE_VOLUME_BREAKOUT_MIN_PRICE_SURGE_PCT=5
ARBITRAGE_VOLUME_BREAKOUT_MIN_VOLUME_SPIKE=3
ARBITRAGE_PANIC_DUMP_MIN_SELL_SURGE_PCT=20
ARBITRAGE_PANIC_DUMP_MIN_BUY_WALL_RATIO=0.15
ARBITRAGE_STALE_LISTING_MIN_ROI_PCT=10
ARBITRAGE_STALE_LISTING_MAX_YYYP_SELL_NUM=15
ARBITRAGE_STALE_LISTING_MIN_7D_VOLUME=5
ARBITRAGE_STALE_LISTING_MIN_PRICE_DEVIATION_PCT=15
ARBITRAGE_MEAN_REVERSION_MIN_SUPPORT_RATIO=3
ARBITRAGE_MEAN_REVERSION_MIN_TOTAL_SELL_LISTINGS=2000
ARBITRAGE_ACCUMULATION_MAX_VOLATILITY=0.03
ARBITRAGE_ACCUMULATION_MIN_SELL_DECLINE=0.20
ARBITRAGE_ACCUMULATION_MIN_VOLUME_AMP=1.5
QQ_BOT_WEBHOOK_URL=
NOTIFY_WEBHOOK_TIMEOUT_SECONDS=8

# 监控异常策略（K线衍生）
ANOMALY_BOLLINGER_WINDOW=48
ANOMALY_BOLLINGER_TOUCH_RATIO=1.02
ANOMALY_INVENTORY_LOOKBACK_POINTS=24
ANOMALY_INVENTORY_SLOPE_THRESHOLD_PCT=-8
ANOMALY_FLASH_DROP_MIN_RATIO=0.85
ANOMALY_RECENT_MIN_POINTS=24
ANOMALY_WHALE_LOOKBACK_POINTS=24
ANOMALY_WHALE_STABLE_CV_MAX=0.25
ANOMALY_WHALE_VOLUME_SPIKE_MULTIPLIER=2.5

# 庄家监控任务
MARKET_MAKER_DETECT_IN_SYNC=false
WHALE_MONITOR_ENABLED=true
WHALE_MONITOR_MIN_PRICE=500
WHALE_MONITOR_MAX_ITEMS=200
WHALE_ALERT_MIN_SEVERITY=medium
WHALE_ALERT_MAX_PER_RUN=20
TIERED_NOTIFY_MAX_ITEMS=20

# ==========================================
# 前端配置
# ==========================================

# 浏览器访问 API 地址（可选）
# 为空时自动使用同源地址（推荐：由 Nginx 反代 /api）。
# 本地直连示例: http://localhost:8000
NEXT_PUBLIC_API_URL=

# 浏览器访问 WebSocket 地址（可选）
# 为空时自动使用同源地址并切换协议（http->ws, https->wss）。
# 本地直连示例: ws://localhost:8001
NEXT_PUBLIC_WS_URL=
