# CS 饰品数据采集系统 - 环境变量配置

# ==========================================
# 第三方API配置
# ==========================================

# Pricempire API (历史数据)
# 获取地址: https://pricempire.com/api
# 免费额度: 100次/天
PRICEMPIRE_API_KEY=your_pricempire_api_key_here

# SteamDT API (多平台数据聚合)
# 官方文档: https://steamdt.com/
# 支持平台: Steam, Buff, 悠悠有品等
# 多Key轮换策略: 提高请求额度
STEAMDT_API_KEY_1=e0ddd0c837ce48978f0c4fe0a5509fa4
STEAMDT_API_KEY_2=aa17f908ee294ae1b7eaba233abf857e
STEAMDT_API_KEY_3=79065a1eef8841d3b3eba7140b790257
STEAMDT_API_KEY_4=d7dd28cf87de4d2a81ff0881f4e82955
STEAMDT_API_KEY_5=dcde904a905c478186966a30654b61d9
STEAMDT_API_KEYS=e0ddd0c837ce48978f0c4fe0a5509fa4,aa17f908ee294ae1b7eaba233abf857e,79065a1eef8841d3b3eba7140b790257,d7dd28cf87de4d2a81ff0881f4e82955,dcde904a905c478186966a30654b61d9

# 悠悠有品 (UU有品) 配置
# 官网: https://www.youpin898.com/
# 数据获取方式: 通过 SteamDT API 或直接爬虫
YOUPIN_ENABLED=true
YOUPIN_API_KEY=  # 如果有独立API则填写

# ==========================================
# 数据库配置
# ==========================================

# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/cs_items
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cs_items
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ==========================================
# DragonflyDB 配置
# ==========================================

DRAGONFLY_URL=redis://:your_dragonfly_password@localhost:6379/0
DRAGONFLY_PASSWORD=your_dragonfly_password_here

# ==========================================
# Celery 配置
# ==========================================

CELERY_BROKER_URL=redis://:your_dragonfly_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_dragonfly_password@localhost:6379/2

# ==========================================
# 应用配置
# ==========================================

# JWT 认证
SECRET_KEY=your_jwt_secret_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 采集配置 (限流策略)
# Steam Market (官方API)
STEAM_DELAY_MIN=2.0
STEAM_DELAY_MAX=3.0

# Buff163 (通过SteamDT API)
BUFF_DELAY_MIN=2.5
BUFF_DELAY_MAX=3.5

# 悠悠有品 (通过SteamDT API或爬虫)
YOUPIN_DELAY_MIN=2.5
YOUPIN_DELAY_MAX=3.5

# SteamDT API 通用配置
STEAMDT_DELAY_MIN=1.5
STEAMDT_DELAY_MAX=2.5
STEAMDT_MAX_REQUESTS_PER_MINUTE=30

# 日志配置
LOG_LEVEL=INFO

# 实例ID (用于高可用部署)
INSTANCE_ID=instance-A

# ==========================================
# 前端配置
# ==========================================

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
